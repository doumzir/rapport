# Base de données PostgreSQL (fourni par Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clé API Anthropic (claude.ai → API keys)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Clé secrète pour sécuriser l'API (génère avec : openssl rand -hex 32)
API_KEY=change_me_with_a_strong_secret

# Timezone pour le scheduler (ex: Europe/Paris)
TZ=Europe/Paris
